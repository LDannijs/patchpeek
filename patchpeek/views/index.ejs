<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>PatchPeek</title>
    <link rel="icon" href="/favicon.svg" type="image/x-icon" />
    <link rel="stylesheet" href="/styles.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/github-markdown-css/5.9.0/github-markdown-dark.min.css"
    />
  </head>
  <body>
    <div class="header">
      <h1 class="title"><img class="logo" src="/favicon.svg"> PatchPeek</h1>
      <p class="lastUpdated">
        Last updated: <span id="lastUpdatedTime" data-timestamp="<%= lastUpdateTime %>"></span>
        <button type="button" id="timeFormatToggle" class="timeFormatToggle" title="Toggle 12h/24h time format"></button>
      </p>
      <form method="POST" action="/refresh" class="refreshForm">
        <button class="refreshButton" type="submit">
          Refresh
        </button>
      </form>
      <details class="settings">
        <summary class="settingsSummary">
          <p class="settingsTitle" >Settings</p>
        </summary>
        <div class="settingsContent">
          <form method="POST" action="/update-days">
            <label for="daysWindow">Show releases from the last</label>
            <input
              type="number"
              id="daysWindow"
              name="daysWindow"
              min="1"
              value="<%= daysWindow %>"
              required
              class="dayswindow"
              onchange="this.form.submit()"
            />
            days
          </form>
          <hr>
          <form action="/update-token" method="POST" class="updatetoken">
            <label for="githubToken">GitHub Token:</label>
            <input id="githubToken" type="text" name="githubToken" placeholder="github_pat_... / ghp_..." />
          </form>
        </div>
      </details>
    </div>
    <div class="layout">
      <div class="content">
        <% if (errorMessage && errorMessage.length) { %>
          <div class="banner">
            <div class="errorMessage">
              <% errorMessage.forEach(err => { %>
                <p><%= err %></p>
              <% }) %>
            </div>
            <a
              class="dismiss-button"
              href="/"
              aria-label="Dismiss error message"
            >&times;</a>
          </div>
        <% } %>
        <% if (rateLimited) { %>
          <div class="banner">
            <p>Rate limit exceeded. Either wait or use a GitHub token.</p>
          </div>
        <% } %>

        <% allReleases.forEach(repo => { %>
          <details class="wrapper">
            <summary class="repoMain">
              <img class="avatar" src="https://github.com/<%= repo.repo.split('/')[0] %>.png"/>
              <p class="project"><%= repo.repo %></p>
              <p class="releaseCount <%= repo.hasFlagged ? 'flagged' : '' %>">
                <%= repo.releaseCount %> releases
              </p>
            </summary>
            <div class="releaseDiv">
              <% repo.releases.forEach(release => { %>
                <details open class="release <%= release.flagged ? 'flagged' : '' %>">
                  <summary class="<%= release.flagged ? 'flagged' : '' %>">
                    <a class="releaseName <%= release.flagged ? 'flagged' : '' %>" href="<%= release.html_url %>" target="_blank">
                      <%= release.name || release.tag_name %> 
                      (<%= new Date(release.published_at).toLocaleDateString() %>)
                    </a>
                  </summary>
                  <div class="markdown-body">
                    <%- release.body_html %>
                  </div>
                </details>
              <% }) %>
            </div>
          </details>
        <% }) %>
      </div>
      <div class="sidebar">
        <h2 id="repositories">Repositories</h2>
        <form method="POST" action="/add-repo" class="addrepo">
          <label for="repoSlug">Enter GitHub repository:</label>
          <input
            id="repoSlug"
            name="repoSlug"
            type="text"
            placeholder="github.com/... OR user/repo"
            required
          />
        </form>
        <hr>
        <ul class="reposlist">
          <% if (repoList.length) { %>
            <% repoList.forEach(repo => { %>
              <li>
                <form method="POST" action="/remove-repo">
                  <code class="repos">
                    <input
                      type="checkbox"
                      name="repoSlug"
                      value="<%= repo %>"
                      class="repocheck"
                      checked
                      onclick="if(confirm('Are you sure you want to remove this repository?')) this.form.submit(); else this.checked = true;"
                    />
                    <p class="repotext"><%= repo %></p>
                  </code>
                  <input type="hidden" name="repoSlug" value="<%= repo %>" />
                </form>
              </li>
            <% }) %>
          <% } else { %>
            <li><em>None yet</em></li>
          <% } %>
        </ul>
      </div>
    </div>
    <div id="loadingOverlay" style="display: none;">  
      <div class="spinner"></div>
    </div>
  </body>
  <script>
    document.querySelectorAll('form').forEach((form) =>
      form.addEventListener('submit', () => {
        document.getElementById('loadingOverlay').style.display = 'flex';
      }),
    );

    const timeEl = document.getElementById('lastUpdatedTime');
    const toggleButton = document.getElementById('timeFormatToggle');

    function renderLastUpdated() {
      const use12h = localStorage.getItem('timeFormat') !== '24';
      timeEl.textContent = timeEl.dataset.timestamp
        ? new Date(timeEl.dataset.timestamp).toLocaleString(undefined, { hour12: use12h })
        : 'never';
      toggleButton.textContent = use12h ? '24h' : '12h';
    }

    toggleButton.addEventListener('click', () => {
      localStorage.setItem('timeFormat', localStorage.getItem('timeFormat') !== '24' ? '24' : '12');
      renderLastUpdated();
    });

    renderLastUpdated();
  </script>
</html>
